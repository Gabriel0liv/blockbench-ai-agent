{
  "name": "blockbench-ai-agent-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Blockbench AI Agent Monorepo Workspace",
  "scripts": {
    "build": "pnpm --filter @blockbench-ai-agent/shared build && pnpm --filter @blockbench-ai-agent/agent-server build && pnpm --filter @blockbench-ai-agent/blockbench-plugin build",
    "dev:server": "pnpm --filter @blockbench-ai-agent/agent-server dev",
    "dev:plugin": "pnpm --filter @blockbench-ai-agent/blockbench-plugin dev",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5"
  }
}
